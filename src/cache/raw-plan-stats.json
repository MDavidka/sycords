{
  "path": "/stats",
  "title": "Stats",
  "structure": {
    "name": "div",
    "props": {
      "className": "min-h-screen flex flex-col items-center justify-center bg-background text-foreground p-4"
    },
    "children": [
      {
        "name": "h2",
        "props": {
          "className": "text-3xl font-semibold mb-6"
        },
        "text": "Game Statistics"
      },
      {
        "name": "Table",
        "props": {
          "className": "w-full max-w-md"
        },
        "children": [
          {
            "name": "TableHeader",
            "children": [
              {
                "name": "TableRow",
                "children": [
                  {
                    "name": "TableHead",
                    "text": "Metric"
                  },
                  {
                    "name": "TableHead",
                    "text": "Value"
                  }
                ]
              }
            ]
          },
          {
            "name": "TableBody",
            "children": [
              {
                "name": "TableRow",
                "children": [
                  {
                    "name": "TableCell",
                    "text": "Cookies"
                  },
                  {
                    "name": "TableCell",
                    "text": "$state.cookieCount"
                  }
                ]
              },
              {
                "name": "TableRow",
                "children": [
                  {
                    "name": "TableCell",
                    "text": "Clicks"
                  },
                  {
                    "name": "TableCell",
                    "text": "$state.totalClicks"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "name": "Button",
        "props": {
          "variant": "outline",
          "size": "sm",
          "onClick": "$handler.goHome"
        },
        "text": "Back to Game"
      }
    ]
  }
}